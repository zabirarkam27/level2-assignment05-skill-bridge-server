model BlogPost {
  id        String   @id @default(uuid())
  title     String
  excerpt   String
  content   String
  image     String?
  tags      String[] @default([])
  isPublished Boolean @default(true)
  authorId  String
  author    User     @relation("BlogPosts", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([isPublished])
  @@index([createdAt])
}
