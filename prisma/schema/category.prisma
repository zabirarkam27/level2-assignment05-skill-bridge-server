model Category {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  image       String?
  tutors      TutorCategory[]
  courses     Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String  @id @default(uuid())
  title       String
  description String?
  image       String?
  isPopular   Boolean @default(false)
  categoryId  String
  createdById String
  tutorId     String?

  category  Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy User     @relation("CoursesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  tutor     User?    @relation("AssignedTutorCourses", fields: [tutorId], references: [id])
  bookings  Booking[]
  deleteRequests CourseDeleteRequest[]
  certificates Certificate[]
  wishlists Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([createdById])
  @@index([isPopular])
}

model CourseDeleteRequest {
  id          String                    @id @default(uuid())
  courseId    String
  requesterId String
  status      CourseDeleteRequestStatus @default(PENDING)
  reason      String?
  resolvedById String?
  resolvedAt  DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  requester User   @relation("CourseDeleteRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("CourseDeleteResolver", fields: [resolvedById], references: [id])

  @@index([courseId])
  @@index([requesterId])
  @@index([status])
}

model TutorCategory {
  tutorId    String
  categoryId String

  tutorProfile TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  Category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([tutorId, categoryId])
  @@index([categoryId])
}
